generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FornecedorStatus {
  ATIVO
  PENDENTE
  BLOQUEADO

  @@map("fornecedor_status")
}

enum AtaStatus {
  ATIVA
  VENCIDA
  CANCELADA
  EM_REVISAO

  @@map("ata_status")
}

enum PedidoStatus {
  RASCUNHO
  PENDENTE
  APROVADO
  EM_TRANSITO
  ENTREGUE
  CANCELADO

  @@map("pedido_status")
}

enum AuditoriaAcao {
  CRIACAO
  ATUALIZACAO
  EXCLUSAO
  APROVACAO
  BLOQUEIO

  @@map("auditoria_acao")
}

model User {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String      @unique
  name      String
  role      String      @default("COMPRADOR")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  auditorias Auditoria[]

  @@map("User")
}

model Fornecedor {
  id     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome   String
  status FornecedorStatus @default(PENDENTE)
  email  String
  atas   Ata[]

  @@map("Fornecedor")
}

model Ata {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  numero       String
  dataInicio   DateTime         @map("dataInicio") @db.Timestamptz(6)
  dataFim      DateTime         @map("dataFim") @db.Timestamptz(6)
  valorTeto    Decimal          @map("valorTeto") @db.Decimal(10, 2)
  fornecedorId String           @map("fornecedorId") @db.Uuid
  status       AtaStatus        @default(ATIVA)
  fornecedor   Fornecedor       @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  medicamentos MedicamentoAta[]
  pedidos      PedidoCompra[]

  @@map("Ata")
}

model MedicamentoAta {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ataId             String             @map("ataId") @db.Uuid
  nome              String
  precoUnitario     Decimal            @map("precoUnitario") @db.Decimal(10, 2)
  quantidadeInicial Int                @map("quantidadeInicial")
  quantidadeUsada   Int                @default(0) @map("quantidadeUsada")
  precoBPS          Decimal            @map("precoBPS") @db.Decimal(10, 2)
  precoCMED         Decimal            @map("precoCMED") @db.Decimal(10, 2)
  ata               Ata                @relation(fields: [ataId], references: [id], onDelete: Cascade)
  pedidoItens       PedidoCompraItem[]

  @@map("MedicamentoAta")
}

model PedidoCompra {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status      PedidoStatus       @default(RASCUNHO)
  ataId       String             @map("ataId") @db.Uuid
  valorTotal  Decimal            @map("valorTotal") @db.Decimal(10, 2)
  dataCriacao DateTime           @default(now()) @map("dataCriacao") @db.Timestamptz(6)
  ata         Ata                @relation(fields: [ataId], references: [id], onDelete: Restrict)
  itens       PedidoCompraItem[]

  @@map("PedidoCompra")
}

model PedidoCompraItem {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId      String         @map("pedidoId") @db.Uuid
  medicamentoId String         @map("medicamentoId") @db.Uuid
  quantidade    Int
  precoUnitario Decimal        @map("precoUnitario") @db.Decimal(10, 2)
  pedido        PedidoCompra   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  medicamento   MedicamentoAta @relation(fields: [medicamentoId], references: [id], onDelete: Restrict)

  @@map("PedidoCompraItem")
}

model Auditoria {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp      DateTime      @default(now()) @db.Timestamptz(6)
  usuarioId      String        @map("usuarioId") @db.Uuid
  acao           AuditoriaAcao
  entidadeId     String        @map("entidadeId")
  detalhes       String
  estadoAnterior Json?         @map("estadoAnterior")
  estadoNovo     Json?         @map("estadoNovo")
  ip             String?
  justificativa  String?
  usuario        User          @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@map("Auditoria")
}
