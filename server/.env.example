# Configurações do Banco de Dados (Supabase)
# Pegue essas URLs em: Project Settings > Database > Connection String

# Transaction Mode (Porta 6543) - Usado pela aplicação para queries
DATABASE_URL="postgresql://postgres.[USUARIO]:[SENHA]@[HOST]:6543/postgres?pgbouncer=true"

# Session Mode (Porta 5432) - Usado pelo Prisma para rodar migrations
DIRECT_URL="postgresql://postgres.[USUARIO]:[SENHA]@[HOST]:5432/postgres"

# Configurações do Servidor
PORT=3001
NODE_ENV=development

# JWT Secret (Para autenticação futura)
JWT_SECRET=sua_chave_secreta_aqui
